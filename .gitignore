# Python
__pycache__/
*.py[cod]
*.db
*.sqlite

# Virtual environment (uv)
.venv/
venv/
.python-version
uv.lock

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

# Node
node_modules/

# Project-specific (regenerate from source)
.session.json

# Runtime directories (track structure with .gitkeep)
# Ignore all runtime artifacts; only allow .gitkeep in the directories we want to keep
materials/*
!materials/.gitkeep
!materials/**/.gitkeep
projects/*
!projects/.gitkeep
exports/*
!exports/.gitkeep
